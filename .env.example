ENVIRONMENT=development
AI_SERVICE_API_KEY=local-dev-ai-service-key

OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=your_openai_api_key_here
Org_ID=your_org_id_here

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

DOCUMENT_EXTRACTOR_ROOT=Agentic-Document-Extraction-PDF
DOCUMENT_EXTRACTOR_ENABLED=true
DOCUMENT_EXTRACTOR_PROVIDER=openai
DOCUMENT_EXTRACTOR_DPI=200
DOCUMENT_EXTRACTOR_MAX_IMAGE_DIMENSION=2048
